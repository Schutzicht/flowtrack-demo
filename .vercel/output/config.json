{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/deelnemers/?$",
			"dest": "_render"
		},
		{
			"src": "^/instellingen/?$",
			"dest": "_render"
		},
		{
			"src": "^/medewerkers/?$",
			"dest": "_render"
		},
		{
			"src": "^/pool/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/pools/?$",
			"dest": "_render"
		},
		{
			"src": "^/reizen/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}