---
import AppLayout from '../../layouts/AppLayout.astro';
import ParticipantChip from '../../components/ParticipantChip.astro';
import Icon from '../../components/Icon.astro';
import Avatar from '../../components/Avatar.astro';
import { getAppContext, buildUrl, roles } from '../../data/context';
import { trips, getTrip, poolsForTrip, winterLocations } from '../../data/trips';
import { participantsByPrefix } from '../../data/participants';
import { getInstructor, instructorsForBranch } from '../../data/instructors';
import { levelDef, getBranch } from '../../data/branches';
import type { Participant } from '../../data/types';

const ctx = getAppContext(Astro.url);
const { id } = Astro.params;
const trip = getTrip(id!);
if (!trip) return Astro.redirect('/dashboard');
const tripPools = poolsForTrip(trip.id);
const branch = getBranch(trip.branchId);
const branchInstructors = instructorsForBranch(trip.branchId);

const cohortMap: Record<string, string> = {
  't-ski-krokus': 'A',
  't-ski-pasen': 'L',
  't-surf-algarve': 'S',
  't-surf-hossegor': 'H',
  't-school-mbo': 'M',
  't-corp-asml': 'C',
};
const prefix = cohortMap[trip.id];
const cohort: Participant[] = prefix ? participantsByPrefix(prefix) : [];

const assignedIds = new Set(tripPools.flatMap((p) => p.participantIds));
const unassigned = cohort.filter((p) => !assignedIds.has(p.id));
const unassignedByLevel = branch.levels.map((lv) => ({ level: lv, participants: unassigned.filter((p) => p.level === lv.id) }));

const dateFmt = (s: string) => new Date(s).toLocaleDateString('nl-NL', { day: '2-digit', month: 'short' });
const clusters = trip.branchId === 'ski'
  ? Array.from(new Set(tripPools.map((p) => p.cluster).filter(Boolean))) as string[]
  : [];

const presence = roles.filter((r) => r.id === 'admin' || r.id === 'coordinator');

const canEdit = ctx.role.permissions.canEditPools;
---
<AppLayout
  ctx={ctx}
  current="pools"
  pageTitle={trip.title}
  pageSubtitle={`${trip.destination} · ${dateFmt(trip.start)} → ${dateFmt(trip.end)}`}
>
  <div class="space-y-4 lg:space-y-5">
    {/* Sticky toolbar — horizontally scrollable on mobile */}
    <div class="card p-2.5 lg:p-3 sticky top-[64px] lg:top-[78px] z-10">
      <div class="flex items-center gap-2 overflow-x-auto scrollbar-none">
        <a href={buildUrl('/pools', ctx.branchId, ctx.roleId)} class="btn btn-icon shrink-0" title="Terug">
          <Icon name="arrow-right" size={15} class="rotate-180" />
        </a>

        {trip.branchId === 'ski' && (
          <>
            <select id="location-select" class="shrink-0 text-[12.5px] px-2.5 py-1.5 rounded-lg border border-line bg-surface font-medium cursor-pointer max-w-[170px] truncate">
              {winterLocations.map((l, i) => (
                <option selected={i === 0}>{l.name} · {l.enrolled} kids</option>
              ))}
            </select>

            {clusters.length > 0 && (
              <div class="flex items-center gap-1 ml-0.5 shrink-0">
                <button data-tab-group="cluster" data-tab="all" class="tab is-active">Alle</button>
                {clusters.map((c) => (
                  <button data-tab-group="cluster" data-tab={`cluster-${c}`} class="tab">{c}</button>
                ))}
              </div>
            )}
          </>
        )}

        <div class="flex-1 min-w-2"></div>

        {canEdit && (
          <>
            <button data-modal="modal-monitor-portal" class="btn btn-ghost shrink-0 hidden sm:inline-flex"><Icon name="qr" size={14} /> <span class="hidden md:inline">Monitor portaal</span></button>
            <button id="btn-reset" class="btn btn-ghost shrink-0 hidden sm:inline-flex"><Icon name="x" size={13} /> Reset</button>
            <button id="btn-auto-assign" class="btn btn-brand shrink-0 hidden lg:inline-flex"><Icon name="sparkles" size={14} /> <span>Auto-indelen</span></button>
          </>
        )}

        <div class="flex items-center gap-2 text-[12px] text-ink-soft pl-2 border-l border-line ml-1 shrink-0">
          <span class="flex -space-x-1.5">
            {presence.map((p) => (
              <span class="ring-2 ring-surface rounded-full">
                <Avatar src={p.avatar} initials={p.initials} size="sm" title={`${p.name} is online`} />
              </span>
            ))}
          </span>
          <span class="hidden xl:inline">2 online</span>
        </div>
      </div>
    </div>

    {/* Live status banner */}
    {trip.branchId === 'ski' && (
      <div class="rounded-2xl bg-navy text-white p-3.5 lg:p-4 flex flex-wrap items-center gap-3 lg:gap-4 border border-navy-2">
        <div class="flex items-center gap-2 text-[12.5px] lg:text-[13px]">
          <span class="w-2 h-2 rounded-full bg-flow pulse-ring"></span>
          <strong>Dag 0</strong> · indeling 95% klaar
        </div>
        <div class="hidden md:block w-px h-5 bg-white/15"></div>
        <div class="text-[12px] lg:text-[12.5px] text-white/65 flex-1 min-w-0">Na dag 1 zijn nog max 5% verschuivingen verwacht. Wijzigingen syncen live.</div>
        <button data-toast="Historie geopend (mock)" class="text-[12px] text-flow hover:underline font-medium shrink-0">Toon historie</button>
      </div>
    )}

    {/* Mobile-only quick actions row */}
    {canEdit && (
      <div class="lg:hidden flex gap-2">
        <button data-modal="modal-monitor-portal" class="btn btn-ghost flex-1"><Icon name="qr" size={14} /> Monitor portaal</button>
        <button id="btn-reset-mobile" class="btn btn-ghost"><Icon name="x" size={13} /></button>
      </div>
    )}

    {/* Builder grid */}
    <div class="grid lg:grid-cols-[300px_1fr] gap-4 lg:gap-5" id="pool-builder">
      {/* LEFT: Unassigned — collapsible on mobile */}
      <aside class="card p-4 h-fit lg:sticky lg:top-[170px] max-h-[60vh] lg:max-h-[calc(100vh-200px)] overflow-y-auto scrollbar-thin">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-[14px] font-display font-bold">Nog in te delen</h3>
          <span id="unassigned-count" class="pill bg-warn/15 text-warn">{unassigned.length}</span>
        </div>

        <input
          type="text"
          placeholder="Zoek deelnemer..."
          class="input mb-3"
          data-filter-input="#pool-builder .participant-chip"
        />

        <div class="space-y-1.5 mb-4 pb-4 border-b border-line">
          <div class="text-[10.5px] uppercase tracking-[0.08em] text-mist font-semibold mb-1">Filter op niveau</div>
          <div class="flex flex-wrap gap-1">
            <button data-filter-level="*" class="filter-btn tab is-active">Alle</button>
            {branch.levels.map((l) => (
              <button data-filter-level={l.id} class="filter-btn tab" style={`color:${l.swatch}`}>{l.shortLabel}</button>
            ))}
          </div>
        </div>

        <div class="space-y-4">
          {unassignedByLevel.map(({ level, participants }) => (
            participants.length > 0 && (
              <div data-level-group={level.id}>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full" style={`background:${level.swatch}`}></span>
                  <span class="text-[11px] uppercase tracking-[0.06em] font-semibold" style={`color:${level.swatch}`}>{level.label}</span>
                  <span class="text-[11px] text-mist">· {participants.length}</span>
                </div>
                <div class="space-y-1.5" data-unassigned-pool>
                  {participants.map((p) => (
                    <ParticipantChip p={p} levelSwatch={level.swatch} levelShort={level.shortLabel} draggable={canEdit} showMedical={ctx.role.permissions.canSeeMedical} />
                  ))}
                </div>
              </div>
            )
          ))}
          {unassigned.length === 0 && (
            <div id="all-assigned" class="text-center py-8 text-[13px] text-ink-soft">
              <div class="w-12 h-12 rounded-full bg-go/10 text-go flex items-center justify-center mx-auto mb-2">
                <Icon name="check" size={20} />
              </div>
              Iedereen ingedeeld.
            </div>
          )}
        </div>
      </aside>

      {/* RIGHT: Pools */}
      <section class="space-y-6">
        {trip.branchId === 'ski' && clusters.length > 0 ? (
          clusters.map((cluster, idx) => {
            const clusterPools = tripPools.filter((p) => p.cluster === cluster);
            return (
              <div data-tab-panel="cluster" data-tab-group="cluster" data-cluster-id={cluster} style={idx > 0 ? '' : ''}>
                <div class="flex items-center gap-2.5 mb-3">
                  <span class="w-8 h-8 rounded-lg bg-ink text-white flex items-center justify-center font-display font-bold text-[13px]">{cluster}</span>
                  <h2 class="text-[16px] font-display font-bold tracking-tight">Cluster {cluster}</h2>
                  <span class="text-[12px] text-ink-soft">· {levelDef(branch.id, clusterPools[0]!.level)?.label}</span>
                  <div class="flex-1 h-px bg-line"></div>
                  <span class="text-[11.5px] text-ink-soft">{clusterPools.length} groepen</span>
                </div>
                <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-3">
                  {clusterPools.map((pool) => {
                    const lvl = levelDef(branch.id, pool.level)!;
                    const inst = getInstructor(pool.instructorId);
                    const pct = Math.min(100, Math.round((pool.participantIds.length / pool.capacity) * 100));
                    const capacityCls = pool.participantIds.length > pool.capacity ? 'is-over' : pool.participantIds.length === pool.capacity ? 'is-full' : '';
                    return (
                      <div class="pool-column card p-3.5 flex flex-col" data-pool-id={pool.id} data-pool-level={pool.level} data-pool-cap={pool.capacity}>
                        <div class="flex items-start justify-between gap-2 mb-2.5">
                          <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-1.5">
                              <span class="w-2 h-2 rounded-full shrink-0" style={`background:${lvl.swatch}`}></span>
                              <span class="text-[13.5px] font-display font-bold tracking-tight truncate">{pool.name}</span>
                            </div>
                            <div class="text-[11px] text-ink-soft mt-0.5">{pool.ageRange[0]}-{pool.ageRange[1]} jr · cap {pool.capacity}</div>
                          </div>
                          <span class="pool-count text-[11px] font-semibold text-mist whitespace-nowrap">{pool.participantIds.length}/{pool.capacity}</span>
                        </div>

                        {inst ? (
                          <div class="flex items-center gap-2 mb-2.5 px-2 py-1.5 rounded-md bg-bg-2 border border-line">
                            <span class="avatar shrink-0">{inst.initials}</span>
                            <div class="flex-1 min-w-0">
                              <div class="text-[12px] font-semibold truncate">{inst.name}</div>
                              <div class="text-[10px] text-ink-soft">monitor · {inst.languages.join('/')}</div>
                            </div>
                            {canEdit && <button data-toast={`Monitor ${inst.name} vervangen`} class="btn-icon w-6 h-6"><Icon name="chevron-down" size={12} /></button>}
                          </div>
                        ) : canEdit && (
                          <button data-modal="modal-pick-monitor" data-toast="Monitor-picker geopend" class="mb-2.5 px-2 py-1.5 rounded-md border border-dashed border-warn/40 text-[12px] text-warn hover:bg-warn/5 text-left">+ Monitor toewijzen</button>
                        )}

                        <div class={`capacity-bar mb-3 ${capacityCls}`}>
                          <span class="pool-bar" style={`width:${pct}%`}></span>
                        </div>

                        <div class="flex-1 min-h-[90px] space-y-1.5" data-drop-zone>
                          {pool.participantIds.map((pid) => {
                            const p = cohort.find((c) => c.id === pid);
                            if (!p) return null;
                            return <ParticipantChip p={p} levelSwatch={lvl.swatch} levelShort={lvl.shortLabel} draggable={canEdit} showMedical={ctx.role.permissions.canSeeMedical} />;
                          })}
                        </div>

                        {pool.meetingPoint && (
                          <div class="mt-2.5 pt-2.5 border-t border-line text-[10.5px] text-ink-soft flex items-center gap-1.5">
                            <Icon name="clock" size={11} /> {pool.meetingPoint}
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })
        ) : (
          <div class="grid sm:grid-cols-2 xl:grid-cols-3 gap-3">
            {tripPools.map((pool) => {
              const lvl = levelDef(branch.id, pool.level)!;
              const inst = getInstructor(pool.instructorId);
              const pct = Math.min(100, Math.round((pool.participantIds.length / pool.capacity) * 100));
              const capacityCls = pool.participantIds.length > pool.capacity ? 'is-over' : pool.participantIds.length === pool.capacity ? 'is-full' : '';
              return (
                <div class="pool-column card p-3.5 flex flex-col" data-pool-id={pool.id} data-pool-level={pool.level} data-pool-cap={pool.capacity}>
                  <div class="flex items-start justify-between gap-2 mb-2.5">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full shrink-0" style={`background:${lvl.swatch}`}></span>
                        <span class="text-[13.5px] font-display font-bold tracking-tight truncate">{pool.name}</span>
                      </div>
                      <div class="text-[11px] text-ink-soft mt-0.5">{pool.ageRange[0]}-{pool.ageRange[1]} jr · cap {pool.capacity} · {lvl.label}</div>
                    </div>
                    <span class="pool-count text-[11px] font-semibold text-mist whitespace-nowrap">{pool.participantIds.length}/{pool.capacity}</span>
                  </div>

                  {inst ? (
                    <div class="flex items-center gap-2 mb-2.5 px-2 py-1.5 rounded-md bg-bg-2 border border-line">
                      <span class="avatar shrink-0">{inst.initials}</span>
                      <div class="flex-1 min-w-0">
                        <div class="text-[12px] font-semibold truncate">{inst.name}</div>
                        <div class="text-[10px] text-ink-soft">{inst.role === 'coordinator' ? 'coordinator' : 'instructeur'} · {inst.languages.join('/')}</div>
                      </div>
                    </div>
                  ) : canEdit && (
                    <button data-modal="modal-pick-monitor" class="mb-2.5 px-2 py-1.5 rounded-md border border-dashed border-warn/40 text-[12px] text-warn hover:bg-warn/5 text-left">+ Instructeur toewijzen</button>
                  )}

                  <div class={`capacity-bar mb-3 ${capacityCls}`}>
                    <span class="pool-bar" style={`width:${pct}%`}></span>
                  </div>

                  <div class="flex-1 min-h-[90px] space-y-1.5" data-drop-zone>
                    {pool.participantIds.map((pid) => {
                      const p = cohort.find((c) => c.id === pid);
                      if (!p) return null;
                      return <ParticipantChip p={p} levelSwatch={lvl.swatch} levelShort={lvl.shortLabel} draggable={canEdit} showMedical={ctx.role.permissions.canSeeMedical} />;
                    })}
                  </div>

                  {pool.meetingPoint && (
                    <div class="mt-2.5 pt-2.5 border-t border-line text-[10.5px] text-ink-soft flex items-center gap-1.5">
                      <Icon name="clock" size={11} /> {pool.meetingPoint}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}
      </section>
    </div>
  </div>

  {/* Floating Auto-indelen FAB — mobile only */}
  {canEdit && (
    <button id="btn-auto-assign-fab" class="fab fab-brand lg:hidden" aria-label="Auto-indelen">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l1.8 5.2L19 9l-5.2 1.8L12 16l-1.8-5.2L5 9l5.2-1.8L12 2z"/></svg>
      Auto-indelen
    </button>
  )}

  <Fragment slot="modals">
    {/* Monitor picker */}
    <dialog id="modal-pick-monitor">
      <header class="px-5 py-4 border-b border-line flex items-start gap-3">
        <div class="flex-1">
          <h3 class="text-[17px] font-display font-bold">{trip.branchId === 'ski' ? 'Monitor' : 'Instructeur'} toewijzen</h3>
          <p class="text-[12.5px] text-ink-soft mt-0.5">Selecteer iemand uit je team. Beschikbaarheid en specialisatie zichtbaar.</p>
        </div>
        <button type="button" data-close-modal class="btn-icon" aria-label="Sluiten"><Icon name="x" size={16} /></button>
      </header>
      <div class="px-5 py-4">
        <input type="text" class="input mb-3" placeholder="Zoek op naam of taal" data-filter-input="#monitor-list > [data-filter-item]" />
        <div id="monitor-list" class="space-y-1.5 max-h-[360px] overflow-y-auto scrollbar-thin">
          {branchInstructors.map((i) => (
            <button data-toast={`${i.name} toegewezen`} data-close-modal data-filter-item data-filter-text={`${i.name} ${i.languages.join(' ')}`.toLowerCase()} class="w-full flex items-center gap-3 p-2.5 rounded-lg border border-line hover:border-flow hover:bg-flow-soft/30 text-left transition-all">
              <span class="avatar avatar-lg bg-flow-soft text-flow-3">{i.initials}</span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-[13.5px] font-semibold truncate">{i.name}</span>
                  <span class={`pill ${i.status === 'available' ? 'bg-go/15 text-go' : i.status === 'busy' ? 'bg-warn/15 text-warn' : 'bg-line-soft text-mist'}`}>{i.status === 'available' ? 'Vrij' : i.status === 'busy' ? 'Bezet' : 'Off'}</span>
                </div>
                <div class="text-[11px] text-ink-soft truncate">{i.specialties.length} specialisaties · {i.languages.join('/')} · ⭐ {i.rating.toFixed(1)}</div>
              </div>
            </button>
          ))}
        </div>
      </div>
    </dialog>

    {/* Monitor portal preview */}
    <dialog id="modal-monitor-portal" style="max-width:720px">
      <header class="px-5 py-4 border-b border-line flex items-start gap-3">
        <div class="flex-1">
          <h3 class="text-[17px] font-display font-bold">Monitor portaal preview</h3>
          <p class="text-[12.5px] text-ink-soft mt-0.5">Wat een monitor op zijn telefoon ziet bij de eerste lift.</p>
        </div>
        <button type="button" data-close-modal class="btn-icon" aria-label="Sluiten"><Icon name="x" size={16} /></button>
      </header>
      <div class="px-5 py-5">
        <div class="grid sm:grid-cols-[260px_1fr] gap-5">
          {/* Phone mockup */}
          <div class="mx-auto sm:mx-0">
            <div class="rounded-[28px] bg-navy p-2.5 shadow-xl w-[240px]">
              <div class="rounded-[22px] bg-bg overflow-hidden">
                <div class="bg-navy text-white px-3 py-3 text-center">
                  <div class="text-[10px] uppercase tracking-[0.08em] text-flow font-semibold">Mijn groep · vandaag</div>
                  <div class="text-[14px] font-display font-bold mt-0.5">Blue Bunnies B1</div>
                  <div class="text-[10.5px] text-white/65">5/6 gescand · 09:30</div>
                </div>
                <div class="p-2.5 space-y-1.5">
                  {cohort.slice(0, 5).map((p) => (
                    <div class="flex items-center gap-2 p-1.5 rounded-md bg-surface border border-line text-[11px]">
                      <span class="avatar bg-flow-soft text-flow-3" style="font-size:9px">{p.initials}</span>
                      <span class="flex-1 font-medium truncate">{p.name}</span>
                      <Icon name="check" size={10} class="text-go" />
                    </div>
                  ))}
                  <div class="flex items-center gap-2 p-1.5 rounded-md bg-warn/10 border border-warn/30 text-[11px]">
                    <span class="avatar bg-warn/20 text-warn" style="font-size:9px">??</span>
                    <span class="flex-1 font-medium text-warn">Wacht op scan</span>
                  </div>
                </div>
                <div class="px-3 py-2.5 border-t border-line bg-bg-2">
                  <button class="w-full text-[11px] font-semibold text-flow">+ Scan volgende</button>
                </div>
              </div>
            </div>
          </div>

          <div class="space-y-3">
            <div class="rounded-xl border border-line p-3">
              <div class="text-[11px] uppercase tracking-[0.08em] text-mist font-semibold mb-1">Wat hij ziet</div>
              <ul class="text-[12.5px] text-ink-soft space-y-1.5 list-disc pl-4">
                <li>Eigen groepsnaam, niveau en startlocatie</li>
                <li>Naam, leeftijd en niveau per kind</li>
                <li>Allergie- en medische info (alleen wat hij mag zien)</li>
                <li>Aanwezigheidsregistratie via QR-scan</li>
                <li>Knop om kind tijdelijk uit groep te halen</li>
              </ul>
            </div>
            <div class="rounded-xl border border-line p-3">
              <div class="text-[11px] uppercase tracking-[0.08em] text-mist font-semibold mb-1">Realtime sync</div>
              <p class="text-[12.5px] text-ink-soft">Verschuivingen die de coordinator doet worden direct gepusht. De monitor kan zelf voorstellen indienen die wachten op approval.</p>
            </div>
            <div class="flex items-center justify-end gap-2">
              <button type="button" data-close-modal class="btn btn-ghost">Sluiten</button>
              <button type="button" data-toast="QR-bandjes batch gegenereerd (mock)" data-close-modal class="btn btn-primary">QR-bandjes genereren</button>
            </div>
          </div>
        </div>
      </div>
    </dialog>
  </Fragment>

  <script type="module" is:inline>
    const root = document.getElementById('pool-builder');
    if (root) {
      let draggingEl = null;
      const flow = window.flow || {};

      const updateCount = () => {
        const remaining = root.querySelectorAll('[data-unassigned-pool] .participant-chip').length;
        const counter = document.getElementById('unassigned-count');
        if (counter) {
          counter.textContent = String(remaining);
          counter.className = remaining === 0
            ? 'pill bg-go/15 text-go'
            : 'pill bg-warn/15 text-warn';
        }
      };

      const updatePoolMetrics = (poolEl) => {
        const cap = parseInt(poolEl.dataset.poolCap, 10);
        const count = poolEl.querySelectorAll('[data-drop-zone] .participant-chip').length;
        const countEl = poolEl.querySelector('.pool-count');
        if (countEl) countEl.textContent = `${count}/${cap}`;
        const barWrap = poolEl.querySelector('.capacity-bar');
        const bar = poolEl.querySelector('.pool-bar');
        if (bar) {
          const pct = Math.min(100, Math.round((count / cap) * 100));
          bar.style.width = pct + '%';
        }
        if (barWrap) {
          barWrap.classList.remove('is-full', 'is-over');
          if (count > cap) barWrap.classList.add('is-over');
          else if (count === cap) barWrap.classList.add('is-full');
        }
      };

      const bindChip = (chip) => {
        chip.addEventListener('dragstart', (e) => {
          draggingEl = chip;
          chip.classList.add('is-dragging');
          e.dataTransfer?.setData('text/plain', chip.dataset.pid || '');
          if (e.dataTransfer) e.dataTransfer.effectAllowed = 'move';
          const lv = chip.dataset.level;
          root.querySelectorAll('.pool-column').forEach((c) => {
            if (c.dataset.poolLevel === lv) c.classList.add('is-drop-target');
          });
        });
        chip.addEventListener('dragend', () => {
          chip.classList.remove('is-dragging');
          draggingEl = null;
          root.querySelectorAll('.pool-column.is-over, .pool-column.is-drop-target').forEach((c) => c.classList.remove('is-over', 'is-drop-target'));
        });
      };
      root.querySelectorAll('.participant-chip').forEach(bindChip);

      const bindZone = (zone) => {
        const poolEl = zone.closest('.pool-column');
        zone.addEventListener('dragover', (e) => {
          e.preventDefault();
          if (poolEl) poolEl.classList.add('is-over');
        });
        zone.addEventListener('dragleave', () => {
          if (poolEl) poolEl.classList.remove('is-over');
        });
        zone.addEventListener('drop', (e) => {
          e.preventDefault();
          if (!draggingEl) return;
          const sourcePool = draggingEl.closest('.pool-column');
          zone.appendChild(draggingEl);
          if (poolEl) {
            poolEl.classList.remove('is-over');
            updatePoolMetrics(poolEl);
            if (flow.toast) flow.toast(`${draggingEl.querySelector('.font-semibold')?.textContent || 'Deelnemer'} → ${poolEl.querySelector('.font-display')?.textContent || 'pool'}`);
          } else if (flow.toast) {
            flow.toast('Terug naar wachtlijst');
          }
          if (sourcePool && sourcePool !== poolEl) updatePoolMetrics(sourcePool);
          updateCount();
        });
      };
      root.querySelectorAll('[data-drop-zone], [data-unassigned-pool]').forEach(bindZone);

      // Reset (desktop + mobile)
      const onReset = () => {
        if (!confirm('Alle handmatige verschuivingen ongedaan maken?')) return;
        location.reload();
      };
      document.getElementById('btn-reset')?.addEventListener('click', onReset);
      document.getElementById('btn-reset-mobile')?.addEventListener('click', onReset);

      // Auto-assign (desktop button + mobile FAB)
      const autoBtn = document.getElementById('btn-auto-assign');
      const autoFab = document.getElementById('btn-auto-assign-fab');
      const autoTriggers = [autoBtn, autoFab].filter(Boolean);
      const runAutoAssign = () => {
        const remaining = Array.from(root.querySelectorAll('[data-unassigned-pool] .participant-chip'));
        if (remaining.length === 0) {
          if (flow.toast) flow.toast('Iedereen is al ingedeeld');
          return;
        }
        autoTriggers.forEach((b) => { b.disabled = true; });
        const label = autoBtn?.querySelector('span');
        if (label) label.textContent = `Indelen 0/${remaining.length}`;
        let i = 0;
        let placed = 0;
        const step = () => {
          if (i >= remaining.length) {
            autoTriggers.forEach((b) => { b.disabled = false; });
            if (label) label.textContent = 'Auto-indelen';
            if (flow.toast) flow.toast(`${placed} deelnemers verdeeld over groepen`);
            return;
          }
          const chip = remaining[i];
          const lv = chip.dataset.level;
          const candidates = Array.from(root.querySelectorAll(`.pool-column[data-pool-level="${lv}"]`));
          const sorted = candidates
            .map((c) => {
              const cap = parseInt(c.dataset.poolCap, 10);
              const count = c.querySelectorAll('[data-drop-zone] .participant-chip').length;
              return { el: c, room: cap - count };
            })
            .filter((x) => x.room > 0)
            .sort((a, b) => b.room - a.room);
          if (sorted.length > 0) {
            const targetZone = sorted[0].el.querySelector('[data-drop-zone]');
            targetZone.appendChild(chip);
            updatePoolMetrics(sorted[0].el);
            placed++;
            updateCount();
          }
          if (label) label.textContent = `Indelen ${i + 1}/${remaining.length}`;
          i++;
          setTimeout(step, 28);
        };
        step();
      };
      autoTriggers.forEach((b) => b.addEventListener('click', runAutoAssign));

      // Filter level buttons
      root.querySelectorAll('.filter-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const f = btn.dataset.filterLevel;
          root.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          root.querySelectorAll('[data-level-group]').forEach((g) => {
            if (f === '*' || g.dataset.levelGroup === f) g.style.display = '';
            else g.style.display = 'none';
          });
        });
      });

      // Cluster tabs (sticky toolbar)
      document.querySelectorAll('[data-tab-group="cluster"]').forEach((tab) => {
        tab.addEventListener('click', (e) => {
          if (!tab.dataset.tab) return;
          const val = tab.dataset.tab;
          document.querySelectorAll('[data-tab-group="cluster"]').forEach((t) => t.classList.remove('is-active'));
          tab.classList.add('is-active');
          if (val === 'all') {
            document.querySelectorAll('[data-cluster-id]').forEach((p) => p.style.display = '');
          } else {
            const wantedCluster = val.replace('cluster-', '');
            document.querySelectorAll('[data-cluster-id]').forEach((p) => {
              p.style.display = p.dataset.clusterId === wantedCluster ? '' : 'none';
            });
          }
        });
      });

      // Location selector — just shows a toast
      document.getElementById('location-select')?.addEventListener('change', (e) => {
        if (flow.toast) flow.toast(`Locatie gewisseld naar ${e.target.value.split(' · ')[0]}`);
      });
    }
  </script>
</AppLayout>
