---
import AppLayout from '../layouts/AppLayout.astro';
import Icon from '../components/Icon.astro';
import { getAppContext } from '../data/context';
import { tripsForBranch } from '../data/trips';
import { participantsByPrefix } from '../data/participants';
import { levelDef } from '../data/branches';

const ctx = getAppContext(Astro.url);
const trips = tripsForBranch(ctx.branchId);

const cohortMap: Record<string, string> = {
  't-ski-krokus': 'A',
  't-ski-pasen': 'L',
  't-surf-algarve': 'S',
  't-surf-hossegor': 'H',
  't-school-mbo': 'M',
  't-corp-asml': 'C',
};

const rows = trips.flatMap((t) => {
  const prefix = cohortMap[t.id];
  if (!prefix) return [];
  return participantsByPrefix(prefix).map((p) => ({ p, trip: t }));
}).slice(0, 80);

const canSeeMedical = ctx.role.permissions.canSeeMedical;
---
<AppLayout ctx={ctx} current="deelnemers" pageTitle="Deelnemers" pageSubtitle={`${rows.length} actieve inschrijvingen — ${ctx.branch.name}`}>
  <div class="space-y-5">
    <div class="flex flex-wrap items-center gap-2.5">
      <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-line bg-surface text-sm text-ink-soft w-full max-w-[320px] focus-within:border-flow transition-all">
        <Icon name="search" size={14} class="text-mist" />
        <input type="text" placeholder="Zoek deelnemer" class="bg-transparent outline-none flex-1 text-[13px]" data-filter-input="[data-filter-item]" />
      </div>
      <details class="dd relative">
        <summary class="btn btn-ghost"><Icon name="filter" size={14} /> Niveau <Icon name="chevron-down" size={12} class="text-mist" /></summary>
        <div class="dd-menu w-[200px]">
          {ctx.branch.levels.map((l) => (
            <button data-toast={`Filter: ${l.label}`} class="dd-item">
              <span class="w-2 h-2 rounded-full" style={`background:${l.swatch}`}></span>
              <span>{l.label}</span>
              <span class="ml-auto text-[11px] text-mist">cap {l.cap}</span>
            </button>
          ))}
        </div>
      </details>
      <details class="dd relative">
        <summary class="btn btn-ghost"><Icon name="filter" size={14} /> Leeftijd <Icon name="chevron-down" size={12} class="text-mist" /></summary>
        <div class="dd-menu w-[180px]">
          {['6-9 jaar', '10-13 jaar', '14-17 jaar', '18+ jaar'].map((r) => (
            <button data-toast={`Filter: ${r}`} class="dd-item"><Icon name="users" size={13} class="text-mist" /> {r}</button>
          ))}
        </div>
      </details>
      <div class="flex-1"></div>
      <button data-toast="Geexporteerd als deelnemers.csv" class="btn btn-ghost"><Icon name="arrow-down" size={14} /> Exporteer CSV</button>
      {ctx.role.permissions.canEditPools && (
        <button data-modal="modal-add-participant" class="btn btn-primary"><Icon name="plus" size={14} /> Deelnemer</button>
      )}
    </div>

    <div class="card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
          <thead class="bg-bg-2 border-b border-line">
            <tr class="text-left">
              <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Naam</th>
              <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Reis</th>
              <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Leeftijd</th>
              <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Niveau</th>
              <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Voorkeur</th>
              {canSeeMedical && <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Medisch</th>}
              <th class="px-4 py-3 font-semibold text-mist text-[10.5px] uppercase tracking-[0.06em]">Contact</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {rows.map(({ p, trip }) => {
              const lvl = levelDef(ctx.branchId, p.level);
              return (
                <tr class="border-b border-line-soft last:border-0 hover:bg-bg-2 transition-colors" data-filter-item data-filter-text={`${p.name} ${trip.title} ${p.age} ${p.level}`.toLowerCase()}>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <span class="avatar avatar-lg" style={lvl ? `background:${lvl.swatch}1A; color:${lvl.swatch}` : ''}>{p.initials}</span>
                      <div>
                        <div class="font-semibold">{p.name}</div>
                        {p.notes && <div class="text-[11px] text-ink-soft">{p.notes}</div>}
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-ink-soft">{trip.title}</td>
                  <td class="px-4 py-3 font-medium">{p.age} jr</td>
                  <td class="px-4 py-3">
                    {lvl && (
                      <span class="pill" style={`background:${lvl.swatch}1A; color:${lvl.swatch}`}>
                        <span class="w-1.5 h-1.5 rounded-full" style={`background:${lvl.swatch}`}></span>
                        {lvl.label}
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-ink-soft">
                    {p.preferences?.length ? (
                      <span class="text-sun flex items-center gap-1 text-[12px]"><Icon name="star" size={11} /> {p.preferences[0]}</span>
                    ) : <span class="text-mist">–</span>}
                  </td>
                  {canSeeMedical && (
                    <td class="px-4 py-3">
                      {p.medical ? (
                        <div class="text-[12px]">
                          {p.medical.allergies && <div class="text-coral font-medium">Allergie: {p.medical.allergies.join(', ')}</div>}
                          {p.medical.notes && <div class="text-ink-soft truncate max-w-[200px]" title={p.medical.notes}>{p.medical.notes}</div>}
                        </div>
                      ) : <span class="text-mist">–</span>}
                    </td>
                  )}
                  <td class="px-4 py-3 text-ink-soft">
                    <div class="text-[12px]">{p.emergencyContact?.name}</div>
                    <div class="text-[11px] text-mist font-mono">{p.emergencyContact?.phone}</div>
                  </td>
                  <td class="px-4 py-3">
                    <button data-toast={`Profiel ${p.name} geopend`} class="btn-icon"><Icon name="chevron-right" size={14} /></button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    {!canSeeMedical && (
      <div class="text-[12px] text-ink-soft flex items-center gap-2 px-1">
        <Icon name="shield" size={12} class="text-mist" />
        Medische gegevens zijn alleen zichtbaar voor medische staf en operations.
      </div>
    )}
  </div>

  <Fragment slot="modals">
    <dialog id="modal-add-participant">
      <header class="px-5 py-4 border-b border-line flex items-start gap-3">
        <div class="flex-1">
          <h3 class="text-[17px] font-display font-bold">Deelnemer toevoegen</h3>
          <p class="text-[12.5px] text-ink-soft mt-0.5">Handmatige inschrijving. Voor bulk-import gebruik je de CSV-upload op het dashboard.</p>
        </div>
        <button type="button" data-close-modal class="btn-icon" aria-label="Sluiten"><Icon name="x" size={16} /></button>
      </header>
      <form data-demo-form="Deelnemer toegevoegd aan wachtlijst" class="px-5 py-5 space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="field-label">Voornaam</label>
            <input class="input" required />
          </div>
          <div>
            <label class="field-label">Achternaam</label>
            <input class="input" required />
          </div>
          <div>
            <label class="field-label">Leeftijd</label>
            <input type="number" class="input" min="4" max="80" required />
          </div>
          <div>
            <label class="field-label">Niveau</label>
            <select class="input" required>
              {ctx.branch.levels.map((l) => <option value={l.id}>{l.label}</option>)}
            </select>
          </div>
          <div class="col-span-2">
            <label class="field-label">Reis</label>
            <select class="input" required>
              {trips.map((t) => <option value={t.id}>{t.title}</option>)}
            </select>
          </div>
          <div class="col-span-2">
            <label class="field-label">Voorkeur — samen met</label>
            <input class="input" placeholder="Bv. Mila Bos" />
          </div>
        </div>
        <footer class="flex items-center justify-end gap-2 pt-2 -mx-5 -mb-5 px-5 py-4 bg-bg-2 border-t border-line rounded-b-[18px]">
          <button type="button" data-close-modal class="btn btn-ghost">Annuleren</button>
          <button type="submit" class="btn btn-primary">Deelnemer toevoegen</button>
        </footer>
      </form>
    </dialog>
  </Fragment>
</AppLayout>
