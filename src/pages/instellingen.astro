---
import AppLayout from '../layouts/AppLayout.astro';
import Icon from '../components/Icon.astro';
import { getAppContext } from '../data/context';
import { branches, roles } from '../data/context';
const ctx = getAppContext(Astro.url);

const settingsTabs = [
  { id: 'workspace', label: 'Workspace', icon: 'settings' },
  { id: 'branches', label: 'Branches & niveaus', icon: 'pools' },
  { id: 'roles', label: 'Rollen & rechten', icon: 'shield' },
  { id: 'survey', label: 'Pre-trip enquete', icon: 'sparkles' },
  { id: 'integrations', label: 'Integraties', icon: 'qr' },
  { id: 'billing', label: 'Facturatie', icon: 'briefcase' },
];
---
<AppLayout ctx={ctx} current="instellingen" pageTitle="Instellingen" pageSubtitle="Workspace, branches, rollen en integraties">
  <div class="grid lg:grid-cols-[260px_1fr] gap-6">
    <nav class="card p-2.5 h-fit lg:sticky lg:top-[160px]">
      {settingsTabs.map((tab, i) => (
        <button
          data-tab-group="settings"
          data-tab={tab.id}
          class={`w-full flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg text-[13px] font-medium tab ${i === 0 ? 'is-active !text-white' : 'text-ink-soft hover:bg-line-soft hover:text-ink'}`}
        >
          <span class="flex items-center gap-2.5"><Icon name={tab.icon} size={15} /> {tab.label}</span>
          <Icon name="chevron-right" size={12} class="opacity-60" />
        </button>
      ))}
    </nav>

    <div>
      <div data-tab-panel="workspace" data-tab-group="settings" class="space-y-5">
        <div class="card p-6">
          <h2 class="text-[18px] font-display font-bold tracking-tight">Workspace</h2>
          <p class="text-[13px] text-ink-soft mt-1">Algemene instellingen van je FlowTrack Planner workspace.</p>

          <form data-demo-form="Workspace-instellingen opgeslagen" class="mt-5 grid sm:grid-cols-2 gap-4 text-[13px]">
            <div>
              <label class="field-label">Organisatie</label>
              <input class="input" value="FlowTrack Travel BV" />
            </div>
            <div>
              <label class="field-label">Tijdzone</label>
              <select class="input">
                <option>Europe/Brussels</option>
                <option>Europe/Amsterdam</option>
                <option>Europe/Paris</option>
              </select>
            </div>
            <div>
              <label class="field-label">Boekingssync</label>
              <input class="input" value="Booking Experts API · elke 15 min" />
            </div>
            <div>
              <label class="field-label">Standaard branche</label>
              <select class="input">
                {branches.map((b) => <option selected={b.id === ctx.branchId}>{b.name}</option>)}
              </select>
            </div>
            <div class="col-span-2 flex items-center justify-end gap-2 mt-2">
              <button type="button" data-toast="Wijzigingen verworpen" class="btn btn-ghost">Annuleren</button>
              <button type="submit" class="btn btn-primary">Opslaan</button>
            </div>
          </form>
        </div>
      </div>

      <div data-tab-panel="branches" data-tab-group="settings" class="space-y-5" style="display:none">
        <div class="card p-6">
          <h2 class="text-[18px] font-display font-bold tracking-tight">Branches & niveau-presets</h2>
          <p class="text-[13px] text-ink-soft mt-1">Per branche eigen niveau-naamgeving en groeps-cap.</p>

          <div class="mt-5 space-y-3">
            {branches.map((b) => (
              <div class="rounded-xl border border-line p-4">
                <div class="flex items-center justify-between mb-3">
                  <div class="font-semibold text-[14px]">{b.name}</div>
                  <button data-toast={`${b.name} branche bewerken`} class="text-[12px] text-flow font-semibold hover:underline">Bewerken</button>
                </div>
                <div class="flex flex-wrap gap-1.5">
                  {b.levels.map((l) => (
                    <span class="pill" style={`background:${l.swatch}1A; color:${l.swatch}`}>
                      <span class="w-1.5 h-1.5 rounded-full" style={`background:${l.swatch}`}></span>
                      {l.label} · max {l.cap}
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div data-tab-panel="roles" data-tab-group="settings" class="space-y-5" style="display:none">
        <div class="card p-6">
          <h2 class="text-[18px] font-display font-bold tracking-tight">Rollen & rechten</h2>
          <div class="mt-4 overflow-x-auto">
            <table class="w-full text-[13px]">
              <thead>
                <tr class="text-left text-mist text-[10.5px] uppercase tracking-[0.06em] border-b border-line">
                  <th class="py-3 pr-3">Rol</th>
                  <th class="py-3 px-2">Pools</th>
                  <th class="py-3 px-2">Reizen</th>
                  <th class="py-3 px-2">Staf</th>
                  <th class="py-3 px-2">Medisch</th>
                  <th class="py-3 px-2">Financieel</th>
                </tr>
              </thead>
              <tbody>
                {roles.map((r) => (
                  <tr class="border-b border-line-soft last:border-0">
                    <td class="py-3 pr-3">
                      <div class="flex items-center gap-2.5">
                        <span class="avatar bg-flow-soft text-flow-3">{r.initials}</span>
                        <div>
                          <div class="font-semibold">{r.name}</div>
                          <div class="text-[11px] text-mist">{r.scope.split(' — ')[0]}</div>
                        </div>
                      </div>
                    </td>
                    {[r.permissions.canEditPools, r.permissions.canEditTrips, r.permissions.canManageStaff, r.permissions.canSeeMedical, r.permissions.canSeeFinance].map((v) => (
                      <td class="py-3 px-2">{v ? <Icon name="check" size={16} class="text-go" /> : <span class="text-mist">—</span>}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div data-tab-panel="survey" data-tab-group="settings" class="space-y-5" style="display:none">
        <div class="card p-6">
          <h2 class="text-[18px] font-display font-bold tracking-tight">Pre-trip enquete</h2>
          <p class="text-[13px] text-ink-soft mt-1">Wordt 8 weken na boeking automatisch verstuurd. Antwoorden vullen profiel.</p>
          <div class="mt-5 flex items-center justify-between p-4 rounded-xl bg-bg-2 border border-line">
            <div>
              <div class="font-semibold text-[14px]">5 vragen actief</div>
              <div class="text-[12px] text-ink-soft mt-0.5">Conversie: 78% (laatste 200 boekingen)</div>
            </div>
            <button data-modal="modal-survey" class="btn btn-primary">Vragen tonen</button>
          </div>
        </div>
      </div>

      <div data-tab-panel="integrations" data-tab-group="settings" class="space-y-5" style="display:none">
        <div class="card p-6">
          <h2 class="text-[18px] font-display font-bold tracking-tight">Integraties</h2>
          <div class="mt-5 space-y-3">
            {[
              { name: 'Booking Experts', desc: 'Inschrijvingen en betalingen', status: 'connected' },
              { name: 'Mollie', desc: 'Aanvullende betaalmethodes', status: 'connected' },
              { name: 'Google Workspace', desc: 'Mail templates voor enquete', status: 'connected' },
              { name: 'Slack', desc: 'Alerts naar #planning kanaal', status: 'disconnected' },
            ].map((i) => (
              <div class="flex items-center gap-3 p-3 rounded-lg border border-line">
                <div class="w-10 h-10 rounded-lg bg-flow-soft text-flow-3 flex items-center justify-center font-bold text-[13px]">{i.name.charAt(0)}</div>
                <div class="flex-1 min-w-0">
                  <div class="text-[13.5px] font-semibold">{i.name}</div>
                  <div class="text-[11.5px] text-ink-soft">{i.desc}</div>
                </div>
                {i.status === 'connected' ? (
                  <span class="pill bg-go/15 text-go">verbonden</span>
                ) : (
                  <button data-toast={`${i.name} koppeling gestart`} class="btn btn-ghost">Koppelen</button>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

      <div data-tab-panel="billing" data-tab-group="settings" class="space-y-5" style="display:none">
        <div class="card p-6">
          <h2 class="text-[18px] font-display font-bold tracking-tight">Facturatie</h2>
          <p class="text-[13px] text-ink-soft mt-1">Demo. Echte facturatie wordt extern beheerd.</p>
          <div class="mt-5 grid sm:grid-cols-2 gap-4">
            <div class="rounded-xl border border-line p-4">
              <div class="text-[11px] uppercase tracking-[0.06em] text-mist font-semibold">Huidig abonnement</div>
              <div class="text-[24px] font-display font-bold mt-2 tracking-tight">FlowTrack Pro</div>
              <div class="text-[13px] text-ink-soft mt-1">€189 / maand · onbeperkt deelnemers</div>
            </div>
            <div class="rounded-xl border border-line p-4">
              <div class="text-[11px] uppercase tracking-[0.06em] text-mist font-semibold">Volgende factuur</div>
              <div class="text-[24px] font-display font-bold mt-2 tracking-tight">15 jun 2026</div>
              <div class="text-[13px] text-ink-soft mt-1">Automatische incasso vanaf rekening</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</AppLayout>
