---
import Base from './Base.astro';
import Sidebar from '../components/Sidebar.astro';
import TopBar from '../components/TopBar.astro';
import type { AppContext } from '../data/context';

interface Props {
  ctx: AppContext;
  current: string;
  title?: string;
  pageTitle?: string;
  pageSubtitle?: string;
}
const { ctx, current, title, pageTitle, pageSubtitle } = Astro.props;
---
<Base title={title ?? 'FlowTrack Planner'}>
  <div class="min-h-screen bg-bg">
    <Sidebar ctx={ctx} current={current} />
    <div class="lg:pl-[260px] min-h-screen flex flex-col">
      <TopBar ctx={ctx} current={current} title={pageTitle} subtitle={pageSubtitle} />
      <main class="flex-1 px-5 lg:px-10 py-6 lg:py-9 animate-fade-up">
        <slot />
      </main>
    </div>
  </div>

  <div id="toast-host" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-2 pointer-events-none">
  </div>

  <slot name="modals" />

  <script src="/scripts/app.js" is:inline></script>
</Base>

<style is:global>
  #toast-host > * { pointer-events: auto; }
</style>
